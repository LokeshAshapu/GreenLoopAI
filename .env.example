# Django Security Settings
SECRET_KEY=django-insecure-greenloop-ai-super-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# format: postgres://user:password@host:port/dbname or sqlite:///db.sqlite3
DATABASE_URL=sqlite:///db.sqlite3

# Security Encryption Keys
# Generate a Fernet key using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=z7yK9Hq2Vp5bT1s_Y3wN8mKxL-Z4dC6fR7gB0hJ1kL8=
HMAC_SECRET_KEY=hmac-secret-signature-verification-token-key-32-chars

# NVIDIA NIM AI Integration
NVIDIA_API_KEY=
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
# If true, uses fallback mock responses without calling the remote NVIDIA endpoint
NVIDIA_MOCK_MODE=True
